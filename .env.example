# --- Usados por check-all-users.js (el chequeo periódico multiusuario) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CREDENTIALS_ENCRYPTION_KEY=
TELEGRAM_TOKEN=

# Opcional. Tu chat_id de Telegram (ej. hablándole a @userinfobot). Si lo
# pones, el bot te avisa por Telegram cuando INTRALU se cae y cuando se
# recupera — sin esto, esos avisos solo quedan en los logs de GitHub Actions.
ADMIN_CHAT_ID=

# --- Opcional: solo para tu propio diagnóstico local con login-test.js ---
UNI_CODIGO=tu_codigo_uni
UNI_PASSWORD=tu_contraseña
